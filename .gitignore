# Obsidian: keep only core-plugins.json (list of enabled plugins), ignore per-machine state + plugin binaries
**/.obsidian/*
!**/.obsidian/core-plugins.json
!**/.obsidian/community-plugins.json

# Claude Code: per-machine local settings
.claude/settings.local.json
.claude/sessions/
.claude/cache/

# Export build artifacts (regenerable — don't version)
**/_export-build/

# Deliverable exports — regenerable from source markdown; don't version
**/_export/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~

# Node (if any tooling lands here — mermaid-cli etc. are global)
node_modules/

# Temp
*.tmp
*.log
