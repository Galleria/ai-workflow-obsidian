# Obsidian: keep only core-plugins.json (list of enabled plugins), ignore per-machine state + plugin binaries
**/.obsidian/*
!**/.obsidian/core-plugins.json
!**/.obsidian/community-plugins.json

# Claude Code: per-machine local settings
.claude/settings.local.json
.claude/sessions/
.claude/cache/

# Export build artifacts (regenerable — don't version)
**/_export-build/

# Deliverable exports — regenerable from source markdown; don't version
**/_export/

# Private project data — raw SOW/TOR originals may contain client-confidential content
# (extracted.md stays tracked; only the raw binary source files are excluded by default)
**/projects/*/_input/raw/*.pdf
**/projects/*/_input/raw/*.docx
**/projects/*/_input/raw/*.doc
**/projects/*/_input/raw/*.xlsx
**/projects/*/_input/raw/*.zip

# markitdown converted artifacts (regenerable from source)
**/projects/*/_input/_converted/
**/knowledge/*/_sources/

# Visibility override: per-project opt-out — create this empty file in a project to
# exclude the entire project directory from git. Useful for strictly-private clients.
# Example:   touch vault/projects/acme/.private
# Then add:  vault/projects/acme/ to a machine-specific .git/info/exclude, OR git rm --cached -r the project.

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~

# Node (if any tooling lands here — mermaid-cli etc. are global)
node_modules/

# Temp
*.tmp
*.log
